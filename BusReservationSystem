import java.util.*;

class Bus {
    int busId, seats;
    String route;
    double fare;

    void input(Scanner sc) {
        System.out.print("Enter Bus ID: ");
        busId = sc.nextInt(); sc.nextLine();

        System.out.print("Enter Route: ");
        route = sc.nextLine();

        System.out.print("Enter Seats: ");
        seats = sc.nextInt();

        System.out.print("Enter Fare: ");
        fare = sc.nextDouble();
    }

    void display() {
        System.out.println(busId+" "+route+" "+seats+" "+fare);
    }
}

public class BusReservationSystem {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        ArrayList<Bus> list = new ArrayList<>();
        int choice;

        do {
            System.out.println("\n1.Add 2.Display 3.Book Seat 4.Delete 5.Exit");
            choice = sc.nextInt();

            switch (choice) {
                case 1:
                    Bus b = new Bus();
                    b.input(sc);
                    list.add(b);
                    break;

                case 2:
                    for (Bus x : list) x.display();
                    break;

                case 3:
                    int id = sc.nextInt();
                    for (Bus x : list)
                        if (x.busId == id && x.seats > 0)
                            x.seats--;
                    break;

                case 4:
                    int del = sc.nextInt();
                    list.removeIf(x -> x.busId == del);
                    break;
            }
        } while (choice != 5);
    }
}
