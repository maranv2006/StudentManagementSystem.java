import java.util.*;

class Item {
    int itemId, quantity;
    String name;
    double price;

    void input(Scanner sc) {
        System.out.print("Enter Item ID: ");
        itemId = sc.nextInt(); sc.nextLine();

        System.out.print("Enter Name: ");
        name = sc.nextLine();

        System.out.print("Enter Quantity: ");
        quantity = sc.nextInt();

        System.out.print("Enter Price: ");
        price = sc.nextDouble();
    }

    void display() {
        System.out.println(itemId+" "+name+" "+price+" "+quantity);
    }
}

public class ShoppingSystem {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        ArrayList<Item> list = new ArrayList<>();
        int choice;

        do {
            System.out.println("\n1.Add 2.Display 3.Total Cost 4.Filter Price 5.Delete 6.Exit");
            choice = sc.nextInt();

            switch (choice) {
                case 1:
                    Item i = new Item();
                    i.input(sc);
                    list.add(i);
                    break;

                case 2:
                    for (Item x : list) x.display();
                    break;

                case 3:
                    double total = 0;
                    for (Item x : list)
                        total += x.price * x.quantity;
                    System.out.println("Total Cost: " + total);
                    break;

                case 4:
                    double min = sc.nextDouble();
                    for (Item x : list)
                        if (x.price > min) x.display();
                    break;

                case 5:
                    int del = sc.nextInt();
                    list.removeIf(x -> x.itemId == del);
                    break;
            }
        } while (choice != 6);
    }
}
