import java.util.*;

class Movie {
    int movieId;
    String name, genre;
    double rating;

    void input(Scanner sc) {
        System.out.print("Enter Movie ID: ");
        movieId = sc.nextInt(); sc.nextLine();

        System.out.print("Enter Name: ");
        name = sc.nextLine();

        System.out.print("Enter Genre: ");
        genre = sc.nextLine();

        System.out.print("Enter Rating: ");
        rating = sc.nextDouble();
    }

    void display() {
        System.out.println(movieId+" "+name+" "+genre+" "+rating);
    }
}

public class MovieManagementSystem {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        ArrayList<Movie> list = new ArrayList<>();
        int choice;

        do {
            System.out.println("\n1.Add 2.Display 3.Top Rated 4.Delete 5.Exit");
            choice = sc.nextInt();

            switch (choice) {
                case 1:
                    Movie m = new Movie();
                    m.input(sc);
                    list.add(m);
                    break;

                case 2:
                    for (Movie x : list) x.display();
                    break;

                case 3:
                    for (Movie x : list)
                        if (x.rating > 4)
                            x.display();
                    break;

                case 4:
                    int del = sc.nextInt();
                    list.removeIf(x -> x.movieId == del);
                    break;
            }
        } while (choice != 5);
    }
}
